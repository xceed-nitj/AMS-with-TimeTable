# python-ml-service environment configuration
# Edit values here and restart the service to apply.

# Where recorded RTSP streams are saved on the server.
# Defaults to ../server/recordings/ (relative to python-ml-service).
# Use an absolute path for a different drive or location.
# Examples:
#   RECORDINGS_DIR=D:\recordings
#   RECORDINGS_DIR=C:\Users\harim\Videos\AMS
#RECORDINGS_DIR=

# Base URL of the Node server, used when this service needs to call back into
# Node (e.g. fetching a ground-truth photo it has no local disk access to).
# Defaults to localhost for co-located dev setups — set this when this
# service runs on a separate machine from the Node server.
# Example:
#   NODE_SERVER_URL=http://10.10.0.5:8010
#NODE_SERVER_URL=
