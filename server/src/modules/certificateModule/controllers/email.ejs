<div style="background:#f4f6fb;padding:32px 16px;font-family:Arial,Helvetica,sans-serif;">
  <div style="max-width:560px;margin:0 auto;background:#ffffff;border-radius:12px;border:1px solid #e4e8f5;overflow:hidden;">
    <div style="background:#0e7490;padding:22px 28px;">
      <div style="color:#ffffff;font-size:20px;font-weight:700;letter-spacing:.02em;">🎓 Your Certificate is Ready</div>
      <div style="color:rgba(255,255,255,.85);font-size:12px;margin-top:4px;">XCEED — NIT Jalandhar</div>
    </div>
    <div style="padding:28px;">
      <p style="margin:0 0 8px;font-size:14px;color:#444;line-height:1.6;">Dear <%= participantName %>,</p>
      <p style="margin:0 0 16px;font-size:14px;color:#444;line-height:1.6;">
        Thank you for participating in
        <strong style="color:#0e7490;"><%= eventName %></strong>.
        Your certificate of participation has been generated and is ready to download.
      </p>
      <div style="background:#f0f9ff;border:1px solid #cfe9f5;border-left:4px solid #0e7490;border-radius:10px;padding:14px 18px;margin:0 0 8px;">
        <p style="margin:0;font-size:14px;color:#444;line-height:1.6;">
          Tap the button below to view and download your certificate.
        </p>
      </div>
      <div style="text-align:center;margin:24px 0;">
        <a href="<%= certificateURL %>" target="_blank"
           style="display:inline-block;background:#0e7490;color:#ffffff;text-decoration:none;font-size:14px;font-weight:600;padding:12px 32px;border-radius:8px;">
          View Certificate
        </a>
      </div>
      <p style="margin:0 0 16px;font-size:12px;color:#888;line-height:1.6;">
        If the button doesn't work, copy and paste this link into your browser:<br />
        <a href="<%= certificateURL %>" target="_blank" style="color:#0e7490;word-break:break-all;"><%= certificateURL %></a>
      </p>
      <p style="margin:0;font-size:14px;color:#444;line-height:1.6;">
        Thanks and Regards,<br />
        <strong style="color:#0e7490;">Team XCEED — NITJ</strong>
      </p>
    </div>
    <div style="padding:14px 28px;border-top:1px solid #e4e8f5;background:#fafbfe;">
      <span style="font-size:11px;color:#999;">Automated email from the XCEED platform — please do not reply.</span>
    </div>
  </div>
</div>
